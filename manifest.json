{
  "manifest_version": 3,
  "name": "Udyam CSP Helper",
  "version": "1.0.0",
  "description": "Bulk Udyam registration for SBI CSP/Kiosk Operators. Semi-automated with human-in-loop for OTP/CAPTCHA.",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://www.udyamregistration.gov.in/*",
    "https://sheets.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Udyam CSP Helper"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.udyamregistration.gov.in/UdyamRegistration.aspx*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
